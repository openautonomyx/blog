---
const { title = 'OpenAutonomyX Blog', description = 'AI systems, autonomous agents, infrastructure, and engineering insights.' } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root { color-scheme: light; --bg: #ffffff; --panel: #ffffff; --line: #e5e7eb; --text: #111827; --muted: #4b5563; --accent: #4f46e5; --accent2: #0891b2; }
      * { box-sizing: border-box; }
      body { margin: 0; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; text-rendering: optimizeLegibility; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .container { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }
      .nav { border-bottom: 1px solid var(--line); background: rgba(255,255,255,.86); backdrop-filter: blur(14px); position: sticky; top: 0; z-index: 10; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 18px 0; }
      .brand { display: flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: -.03em; }
      .logo { width: 34px; height: 34px; border-radius: 12px; background: linear-gradient(135deg, var(--accent), var(--accent2)); }
      .links { display: flex; gap: 22px; color: var(--muted); font-size: 14px; }
      .hero { padding: 84px 0 56px; }
      .eyebrow { color: var(--accent); font-weight: 800; letter-spacing: .16em; text-transform: uppercase; font-size: 13px; }
      h1 { font-size: clamp(44px, 7vw, 78px); line-height: .98; letter-spacing: -.07em; margin: 18px 0 24px; max-width: 900px; }
      .lead { color: var(--muted); font-size: clamp(18px, 2vw, 22px); line-height: 1.7; max-width: 740px; }
      .actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px; }
      .button { display: inline-flex; margin-top: 18px; padding: 11px 15px; border-radius: 999px; border: 1px solid var(--line); background: #f9fafb; font-weight: 700; color: var(--accent); }
      .button.primary { border: 0; background: linear-gradient(135deg, var(--accent), var(--accent2)); color: white; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 34px 0 80px; }
      .card { border: 1px solid var(--line); background: var(--panel); border-radius: 24px; padding: 24px; box-shadow: 0 16px 44px rgba(17,24,39,.08); transition: transform .18s ease, box-shadow .18s ease; }
      .card:hover { transform: translateY(-3px); box-shadow: 0 22px 60px rgba(17,24,39,.12); text-decoration: none; }
      .card h2 { font-size: 24px; letter-spacing: -.04em; margin: 12px 0; }
      .card p, .muted { color: var(--muted); line-height: 1.7; }
      .tag { color: var(--accent2); font-size: 13px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .article { max-width: 820px; padding: 72px 0; }
      .article h1 { font-size: clamp(42px, 7vw, 72px); }
      .article-content { color: #1f2937; font-size: 19px; line-height: 1.85; white-space: pre-wrap; }
      .footer { border-top: 1px solid var(--line); color: var(--muted); padding: 36px 0; margin-top: 60px; }
      @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } .links { display: none; } }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/"><span class="logo"></span><span>OpenAutonomyX</span></a>
        <nav class="links"><a href="/blog/">Blog</a><a href="https://github.com/openautonomyx">GitHub</a></nav>
      </div>
    </header>
    <slot />
    <footer class="footer"><div class="container">© {new Date().getFullYear()} OpenAutonomyX. Built with Astro.</div></footer>
  </body>
</html>
