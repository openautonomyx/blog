---
const { title = 'OpenAutonomyX Blog', description = 'AI systems, autonomous agents, infrastructure, and engineering insights.' } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root { color-scheme: dark; --bg: #070816; --panel: rgba(255,255,255,.06); --line: rgba(255,255,255,.12); --text: #f7f7fb; --muted: #a8adc7; --accent: #8b5cf6; --accent2: #22d3ee; }
      * { box-sizing: border-box; }
      body { margin: 0; background: radial-gradient(circle at top left, rgba(139,92,246,.28), transparent 34rem), radial-gradient(circle at 80% 10%, rgba(34,211,238,.16), transparent 30rem), var(--bg); color: var(--text); font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      a { color: inherit; text-decoration: none; }
      .container { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }
      .nav { border-bottom: 1px solid var(--line); background: rgba(7,8,22,.72); backdrop-filter: blur(14px); position: sticky; top: 0; z-index: 10; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 18px 0; }
      .brand { display: flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: -.03em; }
      .logo { width: 34px; height: 34px; border-radius: 12px; background: linear-gradient(135deg, var(--accent), var(--accent2)); }
      .links { display: flex; gap: 22px; color: var(--muted); font-size: 14px; }
      .hero { padding: 96px 0 70px; }
      .eyebrow { color: #c4b5fd; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; font-size: 13px; }
      h1 { font-size: clamp(48px, 8vw, 88px); line-height: .95; letter-spacing: -.08em; margin: 18px 0 24px; max-width: 900px; }
      .lead { color: var(--muted); font-size: clamp(18px, 2vw, 22px); line-height: 1.7; max-width: 740px; }
      .actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px; }
      .button { padding: 13px 18px; border-radius: 999px; border: 1px solid var(--line); background: var(--panel); font-weight: 700; }
      .button.primary { border: 0; background: linear-gradient(135deg, var(--accent), var(--accent2)); color: white; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin: 42px 0 80px; }
      .card { border: 1px solid var(--line); background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.035)); border-radius: 24px; padding: 24px; }
      .card h2 { font-size: 24px; letter-spacing: -.04em; margin: 12px 0; }
      .card p, .muted { color: var(--muted); line-height: 1.7; }
      .tag { color: #67e8f9; font-size: 13px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .article { max-width: 820px; padding: 72px 0; }
      .article h1 { font-size: clamp(42px, 7vw, 72px); }
      .article-content { color: #e6e8f5; font-size: 19px; line-height: 1.85; white-space: pre-wrap; }
      .footer { border-top: 1px solid var(--line); color: var(--muted); padding: 36px 0; margin-top: 60px; }
      @media (max-width: 800px) { .grid { grid-template-columns: 1fr; } .links { display: none; } }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/"><span class="logo"></span><span>OpenAutonomyX</span></a>
        <nav class="links"><a href="/blog/">Blog</a><a href="https://github.com/openautonomyx">GitHub</a></nav>
      </div>
    </header>
    <slot />
    <footer class="footer"><div class="container">© {new Date().getFullYear()} OpenAutonomyX. Built with Astro.</div></footer>
  </body>
</html>
