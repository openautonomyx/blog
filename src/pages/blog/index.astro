---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAllPosts } from '../../utils/posts.js'

const sortedPosts = getAllPosts().map((post) => ({
  url: `/blog/${post.slug}/`,
  frontmatter: post,
}))
---
<BaseLayout title="Blog | OpenAutonomyX">
  <main class="container hero">
    <p class="eyebrow">Articles</p>
    <h1>OpenAutonomyX Blog</h1>
    <p class="lead">Technical essays on autonomous agents, AI infrastructure, platform engineering, security, and developer tooling.</p>
  </main>
  <section class="container grid">
    {sortedPosts.length === 0 && <p class="muted">No posts published yet.</p>}
    {sortedPosts.map((post) => (
      <a class="card" href={post.url} aria-label={`Read ${post.frontmatter.title}`}>
        <p class="tag">{post.frontmatter.category || 'Engineering'}</p>
        <h2>{post.frontmatter.title}</h2>
        <p>{post.frontmatter.description}</p>
        <p class="muted">{post.frontmatter.date}</p>
        <span class="button">Read article</span>
      </a>
    ))}
  </section>
</BaseLayout>
