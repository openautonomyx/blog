---
import BaseLayout from '../../layouts/BaseLayout.astro'

const sortedPosts = [
  {
    url: '/blog/launching-openautonomyx-blog/',
    frontmatter: {
      title: 'Launching the OpenAutonomyX Blog',
      description: 'A new space for notes on autonomous systems, AI infrastructure, and practical agent engineering.',
      date: '2026-05-22',
      category: 'Announcement',
    },
  },
  {
    url: '/blog/building-agent-infrastructure/',
    frontmatter: {
      title: 'Building Reliable Agent Infrastructure',
      description: 'Reliability matters more than demos when deploying autonomous systems into production.',
      date: '2026-05-22',
      category: 'Engineering',
    },
  },
  {
    url: '/blog/agent-observability/',
    frontmatter: {
      title: 'Agent Observability at Scale',
      description: 'Tracing, monitoring, and debugging autonomous workflows in production.',
      date: '2026-05-22',
      category: 'Operations',
    },
  },
  {
    url: '/blog/multi-agent-workflows/',
    frontmatter: {
      title: 'Designing Multi-Agent Workflows',
      description: 'Coordination patterns for specialized autonomous systems.',
      date: '2026-05-22',
      category: 'Architecture',
    },
  },
  {
    url: '/blog/secure-tool-execution/',
    frontmatter: {
      title: 'Secure Tool Execution for Agents',
      description: 'Permission boundaries, execution sandboxes, and auditability.',
      date: '2026-05-22',
      category: 'Security',
    },
  },
  {
    url: '/blog/evals-and-feedback-loops/',
    frontmatter: {
      title: 'Evaluation and Feedback Loops',
      description: 'How continuous evaluation improves autonomous systems over time.',
      date: '2026-05-22',
      category: 'Research',
    },
  },
]
---
<BaseLayout title="Blog | OpenAutonomyX">
  <main class="container hero">
    <p class="eyebrow">Articles</p>
    <h1>OpenAutonomyX Blog</h1>
    <p class="lead">Technical essays on autonomous agents, AI infrastructure, platform engineering, security, and developer tooling.</p>
  </main>
  <section class="container grid">
    {sortedPosts.map((post) => (
      <a class="card" href={post.url} aria-label={`Read ${post.frontmatter.title}`}>
        <p class="tag">{post.frontmatter.category}</p>
        <h2>{post.frontmatter.title}</h2>
        <p>{post.frontmatter.description}</p>
        <p class="muted">{post.frontmatter.date}</p>
        <span class="button">Read article</span>
      </a>
    ))}
  </section>
</BaseLayout>
