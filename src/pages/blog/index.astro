---
import BaseLayout from '../../layouts/BaseLayout.astro'

const sortedPosts = [
  {
    url: '/blog/launching-openautonomyx-blog/',
    frontmatter: {
      title: 'Launching the OpenAutonomyX Blog',
      description: 'A new space for notes on autonomous systems, AI infrastructure, and practical agent engineering.',
      date: '2026-05-22',
      category: 'Announcement',
    },
  },
  {
    url: '/blog/building-agent-infrastructure/',
    frontmatter: {
      title: 'Building Reliable Agent Infrastructure',
      description: 'Reliability matters more than demos when deploying autonomous systems into production.',
      date: '2026-05-22',
      category: 'Engineering',
    },
  },
]
---
<BaseLayout title="Blog | OpenAutonomyX">
  <main class="container hero">
    <p class="eyebrow">Articles</p>
    <h1>OpenAutonomyX Blog</h1>
    <p class="lead">Technical essays on autonomous agents, AI infrastructure, platform engineering, security, and developer tooling.</p>
  </main>
  <section class="container grid">
    {sortedPosts.map((post) => (
      <a class="card" href={post.url} aria-label={`Read ${post.frontmatter.title}`}>
        <p class="tag">{post.frontmatter.category}</p>
        <h2>{post.frontmatter.title}</h2>
        <p>{post.frontmatter.description}</p>
        <p class="muted">{post.frontmatter.date}</p>
        <span class="button">Read article</span>
      </a>
    ))}
  </section>
</BaseLayout>
